@{
    ViewBag.Title = "Xóa nhà cung cấp";
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="card card-outline card-danger">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Xác nhận xóa nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-1"></i>
                    Bạn đang chuẩn bị xóa nhà cung cấp sau. Hành động này
                    <strong>không thể hoàn tác</strong>.
                </div>

                <table class="table table-bordered">
                    <tbody>
                        <tr>
                            <th style="width: 200px;">Tên nhà cung cấp</th>
                            <td>Công ty ABC</td>
                        </tr>
                        <tr>
                            <th>Tên giao dịch</th>
                            <td>ABC Trading</td>
                        </tr>
                        <tr>
                            <th>Điện thoại</th>
                            <td>0909 123 456</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>contact@abc.com</td>
                        </tr>
                        <tr>
                            <th>Địa chỉ</th>
                            <td>123 Lê Lợi, Quận 1</td>
                        </tr>
                        <tr>
                            <th>Tỉnh / Thành</th>
                            <td>TP. Hồ Chí Minh</td>
                        </tr>
                    </tbody>
                </table>

                <form method="post" class="d-flex justify-content-end">
                    <!-- Ẩn ID nhà cung cấp -->
                    <input type="hidden" name="SupplierId" value="1" />

                    <a href="~/Supplier" class="btn btn-secondary me-2">
                        <i class="bi bi-arrow-left"></i>
                        Quay lại
                    </a>

                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>
                        Xác nhận xóa
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
