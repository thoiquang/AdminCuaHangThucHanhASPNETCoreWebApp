@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

<div class="row">
    <div class="col-12">
        <div class="card card-outline card-primary">

            <!-- HEADER -->
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Mặt hàng
                </h5>
            </div>

            <div class="card-body">

                <!-- FILTER -->
                <form method="get" class="mb-3">
                    <div class="row g-2 align-items-end">

                        <!-- Phân loại -->
                        <div class="col-md-3">
                            <label class="form-label">Phân loại hàng</label>
                            <select name="CategoryId" class="form-select">
                                <option value="">-- Tất cả --</option>
                                <option value="1">Đồ uống</option>
                                <option value="2">Thiết bị điện tử</option>
                            </select>
                        </div>

                        <!-- Nhà cung cấp -->
                        <div class="col-md-3">
                            <label class="form-label">Nhà cung cấp</label>
                            <select name="SupplierId" class="form-select">
                                <option value="">-- Tất cả --</option>
                                <option value="1">Công ty ABC</option>
                                <option value="2">Công ty XYZ</option>
                            </select>
                        </div>

                        <!-- Khoảng giá -->
                        <div class="col-md-2">
                            <label class="form-label">Khoảng giá</label>
                            <input type="number"
                                   name="MinPrice"
                                   class="form-control"
                                   placeholder="Từ">
                        </div>

                        <div class="col-md-2">
                            <label class="form-label invisible">.</label>
                            <input type="number"
                                   name="MaxPrice"
                                   class="form-control"
                                   placeholder="Đến">
                        </div>

                        <!-- Tên mặt hàng -->
                        <div class="col-md-2">
                            <label class="form-label">Tên mặt hàng</label>
                            <div class="input-group">
                                <input type="text"
                                       name="SearchValue"
                                       class="form-control"
                                       placeholder="Nhập tên mặt hàng">
                                <button class="btn btn-primary">
                                    <i class="bi bi-search"></i>
                                </button>
                                <a href="/Product/Create"
                                   class="btn btn-success">
                                    <i class="bi bi-plus-circle"></i>
                                </a>
                            </div>
                        </div>

                    </div>
                </form>

                <!-- RESULT COUNT -->
                <div class="mb-2 text-muted">
                    Tìm thấy <strong>120</strong> mặt hàng
                </div>

                <!-- TABLE -->
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Tên hàng</th>
                                <th>Đơn vị tính</th>
                                <th class="text-end">Giá</th>
                                <th>Trạng thái</th>
                                <th class="text-center" style="width:120px;">
                                    Thao tác
                                </th>
                            </tr>
                        </thead>
                        <tbody>

                            <tr>
                                <td>Sữa tươi Vinamilk</td>
                                <td>Hộp</td>
                                <td class="text-end">25.000</td>
                                <td>
                                    <span class="badge bg-success">
                                        Đang bán
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a href="/Product/Edit/1"
                                       class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/Product/Delete/1"
                                       class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>

                            <tr>
                                <td>Nước ngọt Coca</td>
                                <td>Chai</td>
                                <td class="text-end">10.000</td>
                                <td>
                                    <span class="badge bg-secondary">
                                        Ngừng bán
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a href="/Product/Edit/2"
                                       class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/Product/Delete/2"
                                       class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>

                        </tbody>
                    </table>
                </div>

                <!-- PAGINATION -->
                <nav class="mt-3">
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item disabled">
                            <a class="page-link">«</a>
                        </li>

                        <li class="page-item active">
                            <a class="page-link">1</a>
                        </li>

                        <li class="page-item">
                            <a class="page-link">2</a>
                        </li>

                        <li class="page-item">
                            <a class="page-link">3</a>
                        </li>

                        <li class="page-item">
                            <a class="page-link">»</a>
                        </li>
                    </ul>
                </nav>

            </div>
        </div>
    </div>
</div>