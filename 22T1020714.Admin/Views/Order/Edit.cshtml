@{
    ViewBag.Title = "Cập nhật đơn hàng";
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="card card-outline card-primary">

            <!-- HEADER -->
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-receipt me-2"></i>
                    Cập nhật đơn hàng
                </h5>
            </div>

            <!-- BODY -->
            <div class="card-body">
                <form method="post">
                    <div class="row">

                        <!-- Ngày đặt -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Ngày đặt</label>
                            <input type="date"
                                   name="OrderDate"
                                   class="form-control"
                                   required>
                        </div>

                        <!-- Ngày duyệt -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Ngày duyệt</label>
                            <input type="date"
                                   name="ApprovedDate"
                                   class="form-control">
                        </div>

                        <!-- Trạng thái -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Trạng thái</label>
                            <select name="Status" class="form-select" required>
                                <option value="">-- Chọn trạng thái --</option>
                                <option>Chờ duyệt</option>
                                <option>Đã duyệt</option>
                                <option>Đang giao</option>
                                <option>Hoàn thành</option>
                                <option>Đã hủy</option>
                            </select>
                        </div>

                        <!-- Khách hàng -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Khách hàng</label>
                            <select name="CustomerId"
                                    class="form-select"
                                    required>
                                <option value="">-- Chọn khách hàng --</option>
                                <option value="1">Nguyễn Văn A</option>
                                <option value="2">Lê Thị B</option>
                            </select>
                        </div>

                        <!-- Điện thoại -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input type="text"
                                   name="Phone"
                                   class="form-control"
                                   placeholder="Số điện thoại khách hàng">
                        </div>

                        <!-- Nhân viên xử lý -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nhân viên xử lý</label>
                            <select name="EmployeeId"
                                    class="form-select">
                                <option value="">-- Chọn nhân viên --</option>
                                <option value="1">Trần Thị B</option>
                                <option value="2">Phạm Văn C</option>
                            </select>
                        </div>

                        <!-- Tổng tiền -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tổng tiền</label>
                            <input type="number"
                                   name="TotalAmount"
                                   class="form-control"
                                   min="0"
                                   step="1000"
                                   placeholder="0">
                        </div>

                    </div>

                    <!-- ACTION -->
                    <div class="d-flex justify-content-end mt-3">
                        <a href="/Order"
                           class="btn btn-secondary me-2">
                            <i class="bi bi-arrow-left"></i>
                            Quay lại
                        </a>

                        <button type="submit"
                                class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>
                            Lưu đơn hàng
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
