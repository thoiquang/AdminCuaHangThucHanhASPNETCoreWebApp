@{
    ViewBag.Title = "Xóa người giao hàng";
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="card card-outline card-danger">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Xác nhận xóa người giao hàng
                </h5>
            </div>

            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-1"></i>
                    Bạn đang chuẩn bị xóa người giao hàng sau. Hành động này
                    <strong>không thể hoàn tác</strong>.
                </div>

                <!-- Thông tin người giao hàng -->
                <table class="table table-bordered">
                    <tbody>
                        <tr>
                            <th style="width: 200px;">Tên người giao hàng</th>
                            <td>Giao hàng nhanh</td>
                        </tr>
                        <tr>
                            <th>Số điện thoại</th>
                            <td>1900 636 677</td>
                        </tr>
                    </tbody>
                </table>

                <!-- Form xác nhận -->
                <form method="post" class="d-flex justify-content-end">
                    <!-- ID người giao hàng -->
                    <input type="hidden" name="ShipperId" value="1" />

                    <a href="~/Shipper"
                       class="btn btn-secondary me-2">
                        <i class="bi bi-arrow-left"></i>
                        Quay lại
                    </a>

                    <button type="submit"
                            class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>
                        Xác nhận xóa
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
