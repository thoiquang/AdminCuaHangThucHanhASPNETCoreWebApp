@{
    ViewBag.Title = "Thông tin người giao hàng";
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-truck me-2"></i>
                    Nhập thông tin người giao hàng
                </h5>
            </div>

            <div class="card-body">
                <form method="post">
                    <!-- Tên người giao hàng -->
                    <div class="mb-3">
                        <label class="form-label">Tên người giao hàng</label>
                        <input type="text"
                               name="ShipperName"
                               class="form-control"
                               placeholder="Nhập tên người / đơn vị giao hàng"
                               required />
                    </div>

                    <!-- Số điện thoại -->
                    <div class="mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input type="text"
                               name="Phone"
                               class="form-control"
                               placeholder="Ví dụ: 1900 8095"
                               required />
                    </div>

                    <div class="d-flex justify-content-end mt-3">
                        <a href="/Shipper"
                           class="btn btn-secondary me-2">
                            <i class="bi bi-arrow-left"></i>
                            Quay lại
                        </a>

                        <button type="submit"
                                class="btn btn-primary">
                            <i class="bi bi-save"></i>
                            Lưu dữ liệu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
