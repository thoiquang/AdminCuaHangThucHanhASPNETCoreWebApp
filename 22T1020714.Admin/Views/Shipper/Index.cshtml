@{
    ViewBag.Title = "Quản lý Người giao hàng";
}

<!-- Thanh tìm kiếm + nút thêm mới -->
<div class="row mb-3">
    <div class="col-md-12">
        <form method="get" class="d-flex">
            <input type="text"
                   name="searchValue"
                   class="form-control me-2"
                   placeholder="Nhập tên đơn vị / người giao hàng cần tìm..." />

            <button type="submit" class="btn btn-primary me-2">
                <i class="bi bi-search"></i>
                Tìm kiếm
            </button>

            <a href="/Shipper/Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i>
                Thêm mới
            </a>
        </form>
    </div>
</div>

<!-- Thông báo số kết quả -->
<div class="row mb-2">
    <div class="col-12">
        <span class="text-muted">
            Tìm thấy <strong>12</strong> người giao hàng
        </span>
    </div>
</div>

<!-- Bảng danh sách người giao hàng -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Tên người giao hàng</th>
                    <th>Số điện thoại</th>
                    <th class="text-center" style="width: 120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <!-- Dữ liệu mẫu -->
                <tr>
                    <td>Giao hàng nhanh</td>
                    <td>1900 636 677</td>
                    <td class="text-center">
                        <a href="/Shipper/Edit/1"
                           class="btn btn-sm btn-warning"
                           title="Chỉnh sửa">
                            <i class="bi bi-pencil-square"></i>
                        </a>

                        <a href="/Shipper/Delete/1"
                           class="btn btn-sm btn-danger"
                           title="Xóa"
                           onclick="return confirm('Bạn có chắc muốn xóa người giao hàng này?');">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>

                <tr>
                    <td>Viettel Post</td>
                    <td>1900 8095</td>
                    <td class="text-center">
                        <a href="/Shipper/Edit/2"
                           class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil-square"></i>
                        </a>

                        <a href="/Shipper/Delete/2"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Bạn có chắc muốn xóa người giao hàng này?');">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
<div class="row mt-3">
    <div class="col-12 d-flex justify-content-center">
        <nav>
            <ul class="pagination">
                <li class="page-item disabled">
                    <a class="page-link">«</a>
                </li>

                <li class="page-item active">
                    <a class="page-link" href="#">1</a>
                </li>

                <li class="page-item">
                    <a class="page-link" href="#">2</a>
                </li>

                <li class="page-item">
                    <a class="page-link" href="#">»</a>
                </li>
            </ul>
        </nav>
    </div>
</div>
