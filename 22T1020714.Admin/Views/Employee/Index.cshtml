@{
    ViewBag.Title = "Quản lý Nhân viên";
}

<!-- Thanh tìm kiếm + nút thêm mới -->
<div class="row mb-3">
    <div class="col-md-12">
        <form method="get" class="d-flex">
            <input type="text"
                   name="searchValue"
                   class="form-control me-2"
                   placeholder="Nhập tên nhân viên cần tìm..." />

            <button type="submit" class="btn btn-primary me-2">
                <i class="bi bi-search"></i>
                Tìm kiếm
            </button>

            <a href="~/Employee/Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i>
                Thêm mới
            </a>
        </form>
    </div>
</div>

<!-- Thông báo số kết quả -->
<div class="row mb-2">
    <div class="col-12">
        <span class="text-muted">
            Tìm thấy <strong>12</strong> nhân viên
        </span>
    </div>
</div>

<!-- Bảng danh sách nhân viên -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width: 80px;">Ảnh</th>
                    <th>Tên nhân viên</th>
                    <th>Ngày sinh</th>
                    <th>Số điện thoại</th>
                    <th>Trạng thái</th>
                    <th>Vai trò</th>
                    <th class="text-center" style="width: 180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <!-- Dữ liệu mẫu – sau này foreach Model -->
                <tr>
                    <td class="text-center">
                        <img src="~/images/avatar-default.png"
                             class="rounded-circle"
                             width="50" height="50" />
                    </td>
                    <td>Nguyễn Văn A</td>
                    <td>15/08/1998</td>
                    <td>0909 123 456</td>
                    <td>
                        <span class="badge bg-success">Hoạt động</span>
                    </td>
                    <td>Quản trị</td>
                    <td class="text-center">
                        <a href="~/Employee/Edit/1" class="btn btn-sm btn-primary">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        <a href="~/Employee/ChangePassword/1" class="btn btn-sm btn-info">
                            <i class="bi bi-key"></i>
                        </a>
                        <a href="~/Employee/ChangeRole/1" class="btn btn-sm btn-warning">
                            <i class="bi bi-person-badge"></i>
                        </a>
                        <a href="~/Employee/Delete/1"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Bạn có chắc muốn xóa nhân viên này?');">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>

                <tr>
                    <td class="text-center">
                        <img src="~/images/avatar-default.png"
                             class="rounded-circle"
                             width="50" height="50" />
                    </td>
                    <td>Trần Thị B</td>
                    <td>22/03/2000</td>
                    <td>0912 888 999</td>
                    <td>
                        <span class="badge bg-secondary">Ngừng hoạt động</span>
                    </td>
                    <td>Nhân viên</td>
                    <td class="text-center">
                        <a href="~/Employee/Edit/2" class="btn btn-sm btn-primary">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        <a href="~/Employee/ChangePassword/2" class="btn btn-sm btn-info">
                            <i class="bi bi-key"></i>
                        </a>
                        <a href="~/Employee/ChangeRole/2" class="btn btn-sm btn-warning">
                            <i class="bi bi-person-badge"></i>
                        </a>
                        <a href="~/Employee/Delete/2"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Bạn có chắc muốn xóa nhân viên này?');">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
<div class="row mt-3">
    <div class="col-12 d-flex justify-content-center">
        <nav>
            <ul class="pagination">
                <li class="page-item disabled">
                    <a class="page-link">«</a>
                </li>

                <li class="page-item active">
                    <a class="page-link" href="#">1</a>
                </li>

                <li class="page-item">
                    <a class="page-link" href="#">2</a>
                </li>

                <li class="page-item">
                    <a class="page-link" href="#">3</a>
                </li>

                <li class="page-item">
                    <a class="page-link" href="#">»</a>
                </li>
            </ul>
        </nav>
    </div>
</div>
