@{
    ViewBag.Title = "Phân quyền nhân viên";
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="card card-outline card-warning">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-lock-fill me-2"></i>
                    Phân quyền vai trò nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tên nhân viên</label>
                            <input type="text"
                                   class="form-control"
                                   value="@ViewBag.EmployeeName"
                                   disabled>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tên đăng nhập</label>
                            <input type="text"
                                   class="form-control"
                                   value="@ViewBag.Username"
                                   disabled>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Vai trò</label>
                            <select name="RoleId" class="form-select" required>
                                <option value="">-- Chọn vai trò --</option>
                                <option value="1">Quản trị hệ thống</option>
                                <option value="2">Nhân viên bán hàng</option>
                                <option value="3">Nhân viên kho</option>
                                <option value="4">Người giao hàng</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Trạng thái</label>
                            <select name="IsActive" class="form-select">
                                <option value="true">Đang hoạt động</option>
                                <option value="false">Ngừng hoạt động</option>
                            </select>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Việc thay đổi vai trò sẽ ảnh hưởng đến quyền truy cập của nhân viên trong hệ thống.
                    </div>

                    <div class="text-end">
                        <a href="/Employee" class="btn btn-secondary me-2">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-shield-check"></i> Cập nhật quyền
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
