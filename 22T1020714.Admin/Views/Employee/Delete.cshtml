@{
    ViewBag.Title = "Xóa nhân viên";
}

<div class="row justify-content-center">
    <div class="col-lg-12">
        <div class="card card-outline card-danger">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Xác nhận xóa nhân viên
                </h5>
            </div>

            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-1"></i>
                    Bạn đang chuẩn bị xóa nhân viên sau. Hành động này
                    <strong>không thể hoàn tác</strong>.
                </div>

                <table class="table table-bordered">
                    <tbody>
                        <tr>
                            <th style="width: 200px;">Ảnh đại diện</th>
                            <td>
                                <img src="~/images/avatar-default.png"
                                     class="rounded-circle"
                                     width="80"
                                     height="80" />
                            </td>
                        </tr>
                        <tr>
                            <th>Tên nhân viên</th>
                            <td>Nguyễn Văn A</td>
                        </tr>
                        <tr>
                            <th>Ngày sinh</th>
                            <td>15/08/1998</td>
                        </tr>
                        <tr>
                            <th>Số điện thoại</th>
                            <td>0909 123 456</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>nguyenvana@email.com</td>
                        </tr>
                        <tr>
                            <th>Địa chỉ</th>
                            <td>123 Lê Lợi, Quận 1, TP. Hồ Chí Minh</td>
                        </tr>
                        <tr>
                            <th>Trạng thái</th>
                            <td>
                                <span class="badge bg-success">Hoạt động</span>
                            </td>
                        </tr>
                        <tr>
                            <th>Vai trò</th>
                            <td>Quản trị</td>
                        </tr>
                    </tbody>
                </table>

                <form method="post" class="d-flex justify-content-end">
                    <!-- Ẩn ID nhân viên -->
                    <input type="hidden" name="EmployeeId" value="1" />

                    <a href="~/Employee" class="btn btn-secondary me-2">
                        <i class="bi bi-arrow-left"></i>
                        Quay lại
                    </a>

                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>
                        Xác nhận xóa
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
